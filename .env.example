# Glioma model registry (must match a folder in models_registry/)
GLIOMA__MODEL_VERSION=v1.0.0
GLIOMA__UPLOAD_DIR=data/uploads
GLIOMA__OUTPUT_DIR=data/outputs
GLIOMA__MAX_UPLOAD_SIZE_MB=512

# API Key for authentication (change in production!)
AUTH__API_KEY=change-this-to-a-secure-key

# Database
DB__HOST=database
DB__PORT=5432
DB__NAME=glioma_service
DB__USER=postgres
DB__PASSWORD=postgres

# RabbitMQ
MQ__HOST=rabbitmq
MQ__PORT=5672
MQ__USER=guest
MQ__PASSWORD=guest

# Postgres (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=glioma_service

# RabbitMQ (for docker-compose)
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
